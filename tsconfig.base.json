{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@dashboard-parapente/shared-types": ["./libs/shared-types/src/index.ts"],
      "@dashboard-parapente/design-system": ["./libs/design-system/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
