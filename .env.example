# ==========================================
# Dashboard Parapente - Configuration Example
# ==========================================
# Copy this file to .env and fill in your actual values

# Environment (development | production)
ENVIRONMENT=development

# Database (defaults to sqlite:///./db/dashboard.db)
DATABASE_URL=sqlite:///./db/dashboard.db

# Redis (production only, uses fake redis in development)
REDIS_HOST=redis
REDIS_PORT=6379
USE_FAKE_REDIS=true

# Weather API Keys (get from weatherapi.com and meteoblue.com)
WEATHERAPI_KEY=your_weatherapi_key_here
METEOBLUE_API_KEY=your_meteoblue_key_here

# Strava OAuth (get from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_ACCESS_TOKEN=your_access_token_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dashboard.log

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Telegram (optional, for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
