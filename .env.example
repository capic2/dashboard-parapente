# Docker Compose Environment Variables
# Copy this file to .env and fill in your actual values

# Strava OAuth (get from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Weather API Keys
WEATHERAPI_KEY=your_weatherapi_key_here
METEOBLUE_API_KEY=your_meteoblue_key_here

# Note: Backend has its own .env file in backend/.env
# This file is for docker-compose environment variables in production
