# ============================================
# Dashboard Parapente - Environment Variables
# ============================================

# Environment
ENVIRONMENT=production          # development | production | test

# Redis Configuration
REDIS_HOST=redis               # Nom du service Redis (Docker)
REDIS_PORT=6379                # Port Redis

# Weather API Keys
WEATHERAPI_KEY=your_weatherapi_key_here
METEOBLUE_API_KEY=your_meteoblue_api_key_here

# ============================================
# Optional: Strava Integration
# ============================================
# Décommenter et remplir si vous utilisez Strava

# STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET=your_strava_client_secret
# STRAVA_VERIFY_TOKEN=your_webhook_verify_token

# ============================================
# Optional: Telegram Notifications
# ============================================
# Décommenter et remplir si vous utilisez Telegram

# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# Database (SQLite - Auto-configuré)
# ============================================
# Pas besoin de modifier - géré automatiquement
# DB_PATH=./db/dashboard.db

# ============================================
# Logging
# ============================================
# LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ============================================
# Application Settings
# ============================================
# API_PORT=8001
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. Pour développement local, créez un fichier backend/.env
# 2. Pour production, les variables sont dans docker-compose.yml
# 3. Ne JAMAIS commit de vraies clés API dans Git !
# 4. Les clés WeatherAPI et Meteoblue sont obligatoires
# 5. Strava et Telegram sont optionnels
