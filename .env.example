# ==========================================
# Dashboard Parapente - Configuration
# ==========================================

# Environment (development | production)
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./db/dashboard.db

# Redis (production only, uses fake redis in development)
REDIS_HOST=redis
REDIS_PORT=6379
USE_FAKE_REDIS=false

# Weather API Keys
WEATHERAPI_KEY=your_weatherapi_key_here
METEOBLUE_API_KEY=your_meteoblue_key_here

# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
STRAVA_ACCESS_TOKEN=your_strava_access_token_here
STRAVA_REFRESH_TOKEN=your_strava_refresh_token_here

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO

# ==========================================
# AI Analysis Configuration
# ==========================================

# Google Gemini API (Priority 1 - Recommended for Docker)
# Free tier: 1500 requests/day (more than enough for emagram analysis)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Anthropic API (Priority 3 - Fallback, optional)
ANTHROPIC_API_KEY=your_anthropic_key_here
