# ==========================================
# Dashboard Parapente - Configuration
# ==========================================
#
# Instructions :
# 1. Copier ce fichier vers .env
# 2. Remplacer les valeurs par vos vraies clés API
# 3. Ajuster selon votre environnement (dev/prod)
#
# Note : .env est git-ignoré pour protéger vos secrets
#
# Development tips :
# - En dev : Utiliser BACKEND_USE_FAKE_REDIS=true
# - En dev : Augmenter BACKEND_LOG_LEVEL=DEBUG
# - En prod : BACKEND_LOG_LEVEL=INFO, BACKEND_USE_FAKE_REDIS=false
# ==========================================

# ==========================================
# GLOBAL
# ==========================================

# Environment: development | production
ENVIRONMENT=development

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# Database
# Development: SQLite local (relatif au dossier backend/)
# Production: Chemin complet ou autre DB
BACKEND_DATABASE_URL=sqlite:///./db/dashboard.db

# Redis Cache
# Development: Utiliser fake redis (in-memory, pas de Docker requis)
# Production: Pointer vers le conteneur Redis
BACKEND_REDIS_HOST=redis
BACKEND_REDIS_PORT=6379
BACKEND_USE_FAKE_REDIS=true

# API Server
BACKEND_API_HOST=0.0.0.0
BACKEND_API_PORT=8001
BACKEND_API_DEBUG=false

# Weather API Keys
# WeatherAPI: https://www.weatherapi.com/signup.aspx
# Free tier: 1M requests/month
BACKEND_WEATHERAPI_KEY=your_weatherapi_key_here

# Meteoblue: https://www.meteoblue.com/en/account/apikeys
# Free tier: 50 requests/day
BACKEND_METEOBLUE_API_KEY=your_meteoblue_key_here

# Strava OAuth
# Get credentials: https://www.strava.com/settings/api
# 1. Create an app to get Client ID and Secret
# 2. Use OAuth flow to get Access and Refresh tokens
BACKEND_STRAVA_CLIENT_ID=your_client_id
BACKEND_STRAVA_CLIENT_SECRET=your_client_secret
BACKEND_STRAVA_ACCESS_TOKEN=your_access_token
BACKEND_STRAVA_REFRESH_TOKEN=your_refresh_token
BACKEND_STRAVA_VERIFY_TOKEN=PARAPENTE_2025

# AI Analysis (Emagram)
# Google Gemini: https://aistudio.google.com/app/apikey
# Free tier: 1500 requests/day (recommended)
BACKEND_GOOGLE_API_KEY=your_google_api_key_here
BACKEND_GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (Fallback)
# Get key: https://console.anthropic.com/
# Paid only
BACKEND_ANTHROPIC_API_KEY=your_anthropic_key_here

# Scheduler
# Automatically refresh weather data at regular intervals
BACKEND_SCHEDULER_ENABLED=true
BACKEND_SCHEDULER_INTERVAL_MINUTES=30

# Logging
# Levels: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Development: DEBUG or INFO
# Production: INFO or WARNING
BACKEND_LOG_LEVEL=INFO
BACKEND_LOG_FILE=logs/dashboard.log

# Telegram Alerts (Optional)
# Get bot token: https://t.me/BotFather
# Get chat ID: https://t.me/userinfobot
# Leave empty to disable notifications
BACKEND_TELEGRAM_BOT_TOKEN=
BACKEND_TELEGRAM_CHAT_ID=

# Frontend URL (for CORS, optional)
# Development: http://localhost:5173
# Production: Your deployed frontend URL
BACKEND_FRONTEND_URL=http://localhost:5173

# ==========================================
# FRONTEND CONFIGURATION (Vite)
# ==========================================

# MSW (Mock Service Worker)
# Enable mock data for development/testing
# Set to 'false' to use real backend API
# Default: true (use mocks in dev)
VITE_ENABLE_MSW=true

# API URL
# Point to your backend server
# Development: http://localhost:8001
# Production: Your deployed backend URL
VITE_API_URL=http://localhost:8001
