{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "coverage/",
    "storybook-static/",
    "apps/backend/",
    "apps/e2e/",
    "pnpm-lock.yaml",
    "public/mockServiceWorker.js",
    "**/routeTree.gen.ts",
    "*.tsbuildinfo"
  ]
}
