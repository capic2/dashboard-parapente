# Database
DATABASE_URL=sqlite:////home/capic/.openclaw/workspace/paragliding/db/dashboard.db

# API Keys
WEATHERAPI_KEY=your_weatherapi_key_here
STRAVA_KEY=your_strava_api_key_here
METEOBLUE_API_KEY=***REMOVED***

# Strava OAuth
STRAVA_CLIENT_ID=73115
STRAVA_CLIENT_SECRET=***REMOVED***
STRAVA_ACCESS_TOKEN=***REMOVED***
STRAVA_REFRESH_TOKEN=***REMOVED***

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dashboard.log

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Telegram (optional, for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Deployment
ENVIRONMENT=development  # Use development mode locally (fakeredis instead of real Redis)
USE_FAKE_REDIS=true  # Use in-memory fakeredis in development
