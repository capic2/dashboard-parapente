[run]
source = .
omit = 
    */tests/*
    */migrations/*
    */__pycache__/*
    */venv/*
    */venv_311/*
    */.venv/*
    */site-packages/*
    conftest.py
    */test_*.py

[report]
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov
