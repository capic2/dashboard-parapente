# Database
DATABASE_URL=sqlite:////home/capic/.openclaw/workspace/paragliding/db/dashboard.db

# API Keys
WEATHERAPI_KEY=your_weatherapi_key_here
STRAVA_KEY=your_strava_api_key_here
# Meteoblue API key (free tier: 50 req/day)
# Get your key: https://www.meteoblue.com/en/account/apikeys
METEOBLUE_API_KEY=

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60  # Polling every hour (aligned with cache TTL)
# Note: Cache TTL is 60 minutes in cache.py to match this interval and eliminate gaps

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dashboard.log

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Telegram (optional, for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Deployment
ENVIRONMENT=development

# Redis Cache (optional)
# In dev/test mode, fakeredis (in-memory) is used by default
# Set USE_FAKE_REDIS=false to use a real Redis server
USE_FAKE_REDIS=true
# REDIS_HOST=localhost
# REDIS_PORT=6379
