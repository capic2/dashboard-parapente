{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/design-system/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/design-system/src/**/*.{ts,tsx}"]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/design-system/tsconfig.json"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec storybook dev -p 6007",
        "cwd": "libs/design-system"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec storybook build",
        "cwd": "libs/design-system"
      }
    }
  },
  "tags": ["type:lib", "scope:ui"]
}
