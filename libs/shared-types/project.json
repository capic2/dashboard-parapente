{
  "name": "shared-types",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared-types/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint -c .oxlintrc.json libs/shared-types/src"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt -c .oxfmtrc.json libs/shared-types/src"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt -c .oxfmtrc.json --check libs/shared-types/src"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/shared-types/tsconfig.json"
      }
    }
  },
  "tags": ["type:lib", "scope:shared"]
}
