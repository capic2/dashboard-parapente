# ==========================================
# Dashboard Parapente - Dev Overrides
# ==========================================
# This file provides an example of local development configuration
# Copy to .env.development and adjust values as needed

# Environment
ENVIRONMENT=development

# Database (dev local path - adjust to your path)
DATABASE_URL=sqlite:////path/to/your/workspace/db/dashboard.db

# Redis (use fake redis in dev)
USE_FAKE_REDIS=true

# Logging
LOG_LEVEL=DEBUG
API_DEBUG=true
