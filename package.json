{
  "name": "paragliding-dashboard",
  "version": "1.0.0",
  "description": "Paragliding Dashboard - Weather, Flights, and Analytics - Nx Monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "nx run-many -t serve -p frontend,backend --parallel",
    "build": "nx run-many -t build --all",
    "build:prod": "nx run-many -t build --all --configuration=production",
    "test": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:e2e": "nx e2e e2e",
    "test:e2e:ui": "nx e2e:ui e2e",
    "test:e2e:debug": "nx e2e:debug e2e",
    "test:e2e:report": "nx e2e:report e2e",
    "lint": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "format": "nx run-many -t format --all",
    "graph": "nx graph",
    "knip": "knip"
  },
  "dependencies": {
    "@internationalized/date": "^3.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "cesium": "^1.139.1",
    "date-fns": "^4.0.0",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "ky": "^1.14.3",
    "react": "^19.0.0",
    "react-aria-components": "^1.5.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.1",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@nx/playwright": "^22.6.0",
    "@nx/vite": "^22.6.0",
    "@nx/vitest": "^22.6.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.13",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "chromatic": "^16.0.0",
    "happy-dom": "^20.8.4",
    "knip": "^6.1.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "nx": "^22.6.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.57.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.3",
    "storybook-react-i18next": "^10.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "nx",
      "protobufjs"
    ]
  }
}
