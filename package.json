{
  "name": "paragliding-dashboard",
  "version": "1.0.0",
  "description": "Paragliding Dashboard - Weather, Flights, and Analytics - Nx Monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "nx run-many -t serve -p frontend,backend --parallel",
    "build": "nx run-many -t build --all",
    "build:prod": "nx run-many -t build --all --configuration=production",
    "test": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:e2e": "nx e2e e2e",
    "test:e2e:ui": "nx e2e:ui e2e",
    "test:e2e:debug": "nx e2e:debug e2e",
    "test:e2e:report": "nx e2e:report e2e",
    "lint": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "format": "nx run-many -t format --all",
    "graph": "nx graph"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@internationalized/date": "^3.7.0",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-table": "^8.21.3",
    "cesium": "^1.139.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.0.0",
    "ky": "^1.14.3",
    "react": "^19.0.0",
    "react-aria-components": "^1.5.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@nx/eslint": "^22.6.0",
    "@nx/eslint-plugin": "^22.6.1",
    "@nx/js": "^22.6.0",
    "@nx/playwright": "^22.6.0",
    "@nx/react": "^22.6.0",
    "@nx/vite": "^22.6.0",
    "@nx/workspace": "^22.6.0",
    "@nxlv/python": "^22.1.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/router-plugin": "^1.166.13",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/recharts": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-storybook": "^10.3.3",
    "happy-dom": "^20.8.4",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "nx": "^22.6.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "nx",
      "protobufjs"
    ]
  }
}